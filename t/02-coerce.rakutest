use Test;
use IdClass;

class OrderId does IdClass {
	method prefix { "OrderId" }
}
my $original = OrderId.new;
my OrderId() $coerced = $original.Str;

isa-ok $coerced, OrderId, "type constraint coerce returns correct type";
is $coerced.Str, $original.Str, "type constraint coerce preserves value";

dies-ok { my OrderId() $bad = "Unknown-abc-def" }, "unknown prefix dies";

dies-ok { my OrderId() $bad = "bad-format" }, "invalid format dies";

done-testing;
